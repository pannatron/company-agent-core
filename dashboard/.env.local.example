# ============================================================
# Dashboard environment — แก้ไฟล์นี้แล้วเซฟเป็น .env.local
# ============================================================

# ----------------------------------------------------------------
# Claude Agent SDK
# ----------------------------------------------------------------
# โดย default ใช้ Claude Code login (Max/Pro/Team) จาก ~/.claude/
# ตั้งค่าด้านล่างเฉพาะถ้าอยากใช้ API key

# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------
# Gemini (Google AI Studio) — image generation
# ----------------------------------------------------------------
# ขอ key ที่ https://aistudio.google.com/apikey
# ใช้สำหรับ /api/render/gemini-image (เจนรูปจาก prompt)
# GEMINI_API_KEY=AIzaSy...

# ----------------------------------------------------------------
# Google Drive sync
# ----------------------------------------------------------------
# ไม่ต้องตั้ง env — เชื่อม Drive ผ่าน UI ที่แท็บ "📁 Files" → ปุ่ม "+ เชื่อม Drive"
# config จะถูกบันทึกที่ data/.drive-config.json (gitignored)
